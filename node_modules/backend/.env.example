NODE_ENV=development
PORT=4000

# MySQL — same pattern as DB_HOST / DB_USER / etc. (no DATABASE_URL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=panworld_portal

JWT_ACCESS_SECRET=change_me_min_16_chars_access
JWT_REFRESH_SECRET=change_me_min_16_chars_refresh
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

WEB_ORIGIN=http://localhost:5173

# Optional: absolute URLs for uploaded logos (default http://localhost:PORT)
# FILE_PUBLIC_BASE_URL=http://localhost:4000

# Upload directory (relative to backend folder)
UPLOAD_DIR=./uploads
