generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  TEACHER
  HOD
  MANAGEMENT
  CEO
  PROCUREMENT
  PANWORLD_ADMIN
  PUBLISHER
}

enum CountryCode {
  UAE
  KSA
}

enum SchoolPurchaseStatus {
  REGISTERED_NO_ORDERS
  FIRST_ORDER_CONFIRMED
  ACTIVE_REPEAT
}

enum RfqStatus {
  SUBMITTED
  REVIEWED
  QUOTED
  APPROVED
  ORDERED
  DELIVERED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum SampleRequestStatus {
  SUBMITTED
  REVIEWED
  APPROVED
  DISPATCHED
  DELIVERED
}

enum InvoiceStatus {
  OUTSTANDING
  PAID
}

model SchoolGroup {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schools School[]
}

model School {
  id             String               @id @default(cuid())
  name           String
  country        CountryCode
  curriculumType String
  purchaseStatus SchoolPurchaseStatus @default(REGISTERED_NO_ORDERS)
  preferredLang  String               @default("en")
  enabledModules Json
  branding       Json?
  vatRate        Decimal              @db.Decimal(5, 2)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  groupId String?
  group   SchoolGroup? @relation(fields: [groupId], references: [id])

  users          User[]
  wishlists      Wishlist[]
  rfqs           RFQ[]
  orders         Order[]
  invoices       Invoice[]
  supportTickets SupportTicket[]
  certificates   Certificate[]
  sampleRequests SampleRequest[]

  demoRequests       DemoRequest[]
  chatbotLogs        ChatbotLog[]
  recommendationLogs RecommendationLog[]
}

model Publisher {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products       Product[]
  trainingSeries TrainingSeries[]
  webinars       Webinar[]
  resources      Resource[]

  users        User[]
  demoRequests DemoRequest[]
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  passwordHash     String
  firstName        String
  lastName         String
  role             UserRole
  department       String?
  active           Boolean   @default(true)
  preferredLang    String    @default("en")
  lastLoginAt      DateTime?
  impersonatedById String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id])

  publisherId String?
  publisher   Publisher? @relation(fields: [publisherId], references: [id])

  refreshTokens         RefreshToken[]
  wishlistItems         WishlistItem[]
  training              UserTrainingProgress[]
  ticketMessages        SupportMessage[]
  demoRequestsRequested DemoRequest[]
  createdAnnouncements  Announcement[]
  createdTickets        SupportTicket[]
  createdRfqs           RFQ[]
  certificates          Certificate[]
  languagePreference    LanguagePreference?
  webinarRegs           WebinarRegistration[]
  pdEnrollments         PDEnrollment[]
  downloads             Download[]
  feedback              Feedback[]
  npsSurveys            NPSSurvey[]
  notifications         Notification[]
  auditLogs             AuditLog[]
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String
  userAgent String?
  ipAddress String?
  revokedAt DateTime?
  expiresAt DateTime
  createdAt DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Product {
  id            String   @id @default(cuid())
  sku           String   @unique
  name          String
  seriesName    String?
  type          String // TEXTBOOK | LIBRARY | KIT | UNIFORM | RESOURCE
  gradeMin      Int?
  gradeMax      Int?
  subject       String?
  curriculum    String?
  format        String?
  edition       String?
  countryTags   Json
  nccApproved   Boolean  @default(false)
  price         Decimal  @db.Decimal(10, 2)
  coverImageUrl String?
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  publisherId String
  publisher   Publisher @relation(fields: [publisherId], references: [id])

  wishlistItems WishlistItem[]
  rfqItems      RFQItem[]
  orderItems    OrderItem[]

  demoRequests   DemoRequest[]
  sampleRequests SampleRequest[]
}

model Wishlist {
  id        String   @id @default(cuid())
  name      String   @default("Default")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  items WishlistItem[]
}

model WishlistItem {
  id      String   @id @default(cuid())
  addedAt DateTime @default(now())
  tags    Json?

  wishlistId String
  wishlist   Wishlist @relation(fields: [wishlistId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  addedByUserId String?
  addedByUser   User?   @relation(fields: [addedByUserId], references: [id])

  @@index([wishlistId])
  @@index([productId])
}

model DemoRequest {
  id          String   @id @default(cuid())
  requestedAt DateTime @default(now())
  status      String   @default("CREDENTIALS_SENT")
  channelLog  Json?

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id])

  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  publisherId String?
  publisher   Publisher? @relation(fields: [publisherId], references: [id])

  requestedByUserId String?
  requestedByUser   User?   @relation(fields: [requestedByUserId], references: [id])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String
  category  String
  pinned    Boolean  @default(false)
  audience  Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdByUserId String?
  createdByUser   User?   @relation(fields: [createdByUserId], references: [id])
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  title     String
  email     String?
  phone     String?
  whatsapp  String?
  territory Json
  type      String // ACCOUNT_MANAGER | REGIONAL_MANAGER | PUBLISHER_REP
  createdAt DateTime @default(now())
}

model TrainingSeries {
  id          String   @id @default(cuid())
  title       String
  description String
  createdAt   DateTime @default(now())

  publisherId String
  publisher   Publisher @relation(fields: [publisherId], references: [id])

  videos   TrainingVideo[]
  progress UserTrainingProgress[]
}

model TrainingVideo {
  id             String   @id @default(cuid())
  title          String
  durationMin    Int
  orderIndex     Int
  videoUrl       String?
  chapterMarkers Json?
  createdAt      DateTime @default(now())

  seriesId String
  series   TrainingSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
}

model UserTrainingProgress {
  id          String    @id @default(cuid())
  progressPct Int       @default(0)
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  userId   String
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  seriesId String
  series   TrainingSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  @@unique([userId, seriesId])
}

model SupportTicket {
  id          String       @id @default(cuid())
  subject     String
  description String
  status      TicketStatus @default(OPEN)
  priority    String       @default("NORMAL")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  createdByUserId String?
  createdByUser   User?   @relation(fields: [createdByUserId], references: [id])

  messages    SupportMessage[]
  attachments Json?
}

model SupportMessage {
  id        String   @id @default(cuid())
  body      String
  createdAt DateTime @default(now())

  ticketId String
  ticket   SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  authorUserId String?
  authorUser   User?   @relation(fields: [authorUserId], references: [id])
}

model Webinar {
  id          String   @id @default(cuid())
  title       String
  description String
  startsAt    DateTime
  durationMin Int
  createdAt   DateTime @default(now())

  publisherId String
  publisher   Publisher @relation(fields: [publisherId], references: [id])

  registrations WebinarRegistration[]
}

model WebinarRegistration {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  webinarId String
  webinar   Webinar @relation(fields: [webinarId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([webinarId, userId])
}

model PDCourse {
  id          String   @id @default(cuid())
  title       String
  description String
  isPaid      Boolean  @default(false)
  price       Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  enrollments PDEnrollment[]
}

model PDEnrollment {
  id          String    @id @default(cuid())
  progressPct Int       @default(0)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  courseId String
  course   PDCourse @relation(fields: [courseId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
}

model Resource {
  id          String   @id @default(cuid())
  title       String
  description String
  type        String // PDF | PPT | DOC | LINK | VIDEO
  url         String?
  isPremium   Boolean  @default(false)
  tags        Json?
  createdAt   DateTime @default(now())

  publisherId String
  publisher   Publisher @relation(fields: [publisherId], references: [id])

  downloads Download[]
}

model Download {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  resourceId String
  resource   Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Certificate {
  id            String   @id @default(cuid())
  certificateNo String   @unique
  title         String
  issuedAt      DateTime @default(now())
  metadata      Json?

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SampleRequest {
  id          String              @id @default(cuid())
  status      SampleRequestStatus @default(SUBMITTED)
  requestedAt DateTime            @default(now())
  timeline    Json?

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  productId String?
  product   Product? @relation(fields: [productId], references: [id])
}

model RFQ {
  id        String    @id @default(cuid())
  rfqNo     String    @unique
  status    RfqStatus @default(SUBMITTED)
  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  createdByUserId String?
  createdByUser   User?   @relation(fields: [createdByUserId], references: [id])

  items     RFQItem[]
  quotation Quotation?
}

model RFQItem {
  id        String   @id @default(cuid())
  quantity  Int
  unitPrice Decimal? @db.Decimal(10, 2)

  rfqId String
  rfq   RFQ    @relation(fields: [rfqId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model Quotation {
  id        String   @id @default(cuid())
  quoteNo   String   @unique
  subtotal  Decimal  @db.Decimal(12, 2)
  vatAmount Decimal  @db.Decimal(12, 2)
  total     Decimal  @db.Decimal(12, 2)
  fileUrl   String?
  createdAt DateTime @default(now())

  rfqId String @unique
  rfq   RFQ    @relation(fields: [rfqId], references: [id], onDelete: Cascade)
}

model Order {
  id        String   @id @default(cuid())
  orderNo   String   @unique
  status    String   @default("CONFIRMED")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  items    OrderItem[]
  delivery Delivery?
}

model OrderItem {
  id        String  @id @default(cuid())
  quantity  Int
  unitPrice Decimal @db.Decimal(10, 2)

  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model Delivery {
  id          String    @id @default(cuid())
  courier     String
  trackingNo  String
  eta         DateTime?
  deliveredAt DateTime?
  timeline    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Invoice {
  id        String        @id @default(cuid())
  invoiceNo String        @unique
  status    InvoiceStatus @default(OUTSTANDING)
  subtotal  Decimal       @db.Decimal(12, 2)
  vatAmount Decimal       @db.Decimal(12, 2)
  total     Decimal       @db.Decimal(12, 2)
  issuedAt  DateTime      @default(now())
  dueAt     DateTime?
  pdfUrl    String?
  createdAt DateTime      @default(now())

  schoolId String
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String    @id @default(cuid())
  type      String
  title     String
  body      String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ChatbotLog {
  id        String   @id @default(cuid())
  prompt    String
  response  String
  createdAt DateTime @default(now())

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)
}

model RecommendationLog {
  id        String   @id @default(cuid())
  input     Json
  output    Json
  createdAt DateTime @default(now())

  schoolId String?
  school   School? @relation(fields: [schoolId], references: [id], onDelete: SetNull)
}

model Feedback {
  id        String   @id @default(cuid())
  type      String // TRAINING | WEBINAR | PD | SUGGESTION
  rating    Int?
  message   String
  createdAt DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model NPSSurvey {
  id        String   @id @default(cuid())
  score     Int
  comment   String?
  createdAt DateTime @default(now())

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Setting {
  id        String   @id @default(cuid())
  scope     String // GLOBAL | SCHOOL | USER
  key       String
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LanguagePreference {
  id        String   @id @default(cuid())
  lang      String
  rtl       Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model IntegrationSyncLog {
  id        String   @id @default(cuid())
  system    String // ODOO
  direction String // PUSH | PULL
  status    String // OK | ERROR
  message   String?
  payload   Json?
  createdAt DateTime @default(now())
}
