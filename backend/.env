############################################
# PANWORLD SCHOOL PARTNER PORTAL - Environment
############################################
# Copy this file to .env and fill in your values

# Server
PORT=4000
NODE_ENV=development

# Database - MySQL (separate variables)
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=panworld_portal
# MYSQL_SSL=true

# (Optional) Database URL form (if you prefer a single string)
# DATABASE_URL="mysql://root:@localhost:3306/panworld_portal"

# JWT Secrets - Generate strong random strings (min 32 chars recommended)
JWT_ACCESS_SECRET=dev_access_secret_change_me_please_update_32chars
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_please_update_32chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# File Storage
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports

# Client URL(s) (for CORS) - comma-separated
CLIENT_URL=http://localhost:5173

# Optional: Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

